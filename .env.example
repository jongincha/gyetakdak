# Site
NEXT_PUBLIC_SITE_URL=https://gyetakdak.co.kr

# Admin panel (/admin) — required to view the 창업문의 목록 without a full user system
ADMIN_PASSWORD=
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# Supabase — primary inquiry storage. Without these, inquiries fall back to a local
# JSON file (.data/inquiries.json) which does NOT persist on most serverless hosts.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets — real-time inquiry visibility for non-technical admins (no login needed).
# Share the target sheet with the service account email as an Editor.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_TAB=문의목록
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Email notification on new inquiry — set either Resend OR SMTP, not both required.
INQUIRY_ADMIN_EMAIL=
MAIL_FROM=no-reply@gyetakdak.co.kr
RESEND_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Analytics / marketing tags
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_NAVER_ANALYTICS_ID=

# Maps (referenced by /success page copy; wire up when adding the live store map)
NEXT_PUBLIC_KAKAO_MAP_KEY=
